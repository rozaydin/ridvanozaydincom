---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import CookieConsent from '../components/CookieConsent.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="min-h-screen">
    <div class="max-w-content mx-auto px-6">
      <Header />
      <main class="max-w-3xl">
        <h1 class="text-2xl font-semibold text-gray-900 mb-6">Privacy Policy</h1>
        <div class="space-y-6 text-gray-600 leading-relaxed">
          <p>
            This Application (Pratikafa) does not collect, store or infer any type of personal data. This application does not interact with any third party service
            to leak your personal information.
          </p>

          <h2 class="text-xl font-semibold text-gray-900">What Information Do we collect?</h2>

          <p>
            Pratikafa does not collect any personal information or connect to the internet. This application exist solely on your device.
          </p>

          <h2 class="text-xl font-semibold text-gray-900">Contact</h2>

          <p>
            If you have any questions or concerns, please feel free to <a href="mailto:ridvanozaydin@gmail.com">contact me</a>.
          </p>
        </div>
      </main>
      <Footer />
    </div>
    <CookieConsent />
  </body>
</html>
